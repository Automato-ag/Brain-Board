const uint8_t NUM_KNOWN_DEVICES = sizeof(KNOWN_DEVICES) / sizeof(I2CDevice);

void printMatchingDevices(uint8_t addr) {
  for (uint8_t i = 0; i < NUM_KNOWN_DEVICES; i++) {
    const uint8_t* addrs = KNOWN_DEVICES[i].addresses;
    for (uint8_t j = 0; addrs[j] != 0; j++) {
      if (addrs[j] == addr) {
        Serial.printf("           %-14s %s\n",
                      KNOWN_DEVICES[i].part,
                      KNOWN_DEVICES[i].description);
        break;
      }
    }
  }
}

bool isKnownDevice(uint8_t addr) {
  for (uint8_t i = 0; i < NUM_KNOWN_DEVICES; i++) {
    const uint8_t* addrs = KNOWN_DEVICES[i].addresses;
    for (uint8_t j = 0; addrs[j] != 0; j++) {
      if (addrs[j] == addr) return true;
    }
  }
  return false;
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  Wire.begin(6, 7);  // Brain Board V2.0: SDA=IO6, SCL=IO7

  Serial.println("\n=== Automato Brain Board I2C Scanner ===");
  Serial.printf("Database: %d known devices (i2cdevices.org)\n\n", NUM_KNOWN_DEVICES);
  Serial.println("Scanning...\n");

  uint8_t count = 0;

  for (uint8_t addr = 1; addr < 127; addr++) {
    Wire.beginTransmission(addr);
    uint8_t error = Wire.endTransmission();

    if (error == 0) {
      Serial.printf("  [0x%02X] Device found", addr);
      if (!isKnownDevice(addr)) {
        Serial.println(" — Unknown device");
      } else {
        Serial.println(" — possible matches:");
        printMatchingDevices(addr);
      }
      count++;
    } else if (error == 4) {
      Serial.printf("  [0x%02X] Unknown error\n", addr);
    }
  }

  Serial.println();
  Serial.printf("Scan complete. %d device(s) found.\n", count);
  if (count == 0) Serial.println("Check wiring — SDA=IO6, SCL=IO7");
  Serial.println("Press RESET to scan again.");
}

void loop() {}
